  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0421\u0430\u043D\u044F:\r\n\u042F \u0431\u044B \u043D\u0435 \u043F\u043E\u043B\u0435\u0437.\r\n\u0427\u0435\u0441\u0442\u043D\u043E.\r\n\u0415\u0433\u043E\u0440
    \u0442\u0435\u0440\u043F\u0435\u0442\u044C \u043D\u0435 \u043C\u043E\u0433, \u043A\u043E\u0433\u0434\u0430
    \u043A\u0442\u043E \u0442\u043E \u0442\u0440\u043E\u0433\u0430\u043B \u0435\u0433\u043E
    \u043D\u043E\u0443\u0442. \r\n\u0413\u043E\u0432\u043E\u0440\u0438\u043B \u0443
    \u043D\u0435\u0433\u043E \u0442\u0430\u043C \"\u0432\u0441\u0435 \u043F\u043E
    \u043F\u043E\u0440\u044F\u0434\u043A\u0443\".\r\n\u0425\u043E\u0442\u044F \u0441
    \u0435\u0433\u043E \"\u043F\u043E\u0440\u044F\u0434\u043A\u043E\u043C\" \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u0442\u044C\u0441\u044F
    \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u043D \u0441\u0430\u043C.\r\n\u041D\u043E
    \u0441\u0435\u0439\u0447\u0430\u0441 \u0435\u0433\u043E \u043D\u0435\u0442.\r\n\u041C\u0430\u043A\u0441
    \u043D\u0430\u0437\u0432\u0430\u043D\u0438\u0432\u0430\u0435\u0442.\r\n\u0422\u0435\u043B\u0435\u0444\u043E\u043D
    \u0440\u0430\u0437\u0440\u044F\u0436\u0435\u043D.\r\n\u041A\u043B\u044E\u0447\u0438
    \u0434\u043E\u043C\u0430.\r\n\u041A\u0443\u0440\u0442\u043A\u0430 \u0442\u043E\u0436\u0435.\r\n\u0418
    \u043D\u043E\u0443\u0442 \u0442\u043E\u0436\u0435.\r\n\u0410 \u0431\u0435\u0437
    \u043D\u0435\u0433\u043E \u043E\u043D \u0434\u0430\u0436\u0435 \u043A\u043E\u0444\u0435
    \u043F\u0438\u0442\u044C \u043D\u0435 \u0441\u0430\u0434\u0438\u043B\u0441\u044F.\r\n\u0418
    \u0435\u0441\u043B\u0438 \u044F \u043D\u0430\u0439\u0434\u0443 \u0445\u043E\u0442\u044C
    \u0447\u0442\u043E-\u0442\u043E, \u0442\u043E \u0442\u043E\u043B\u044C\u043A\u043E
    \u0437\u0434\u0435\u0441\u044C. "
